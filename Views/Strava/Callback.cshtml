@{
    ViewData["Title"] = "Strava Authorization";
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card">
                <div class="card-body text-center">
                    @if (ViewBag.Success != null)
                    {
                        <div class="alert alert-success" role="alert">
                            <h4 class="alert-heading">Success!</h4>
                            <p>@ViewBag.Success</p>
                            <hr>
                            <p class="mb-0">
                                To complete the setup, you need to exchange the authorization code for access tokens.
                                For now, you can manually add your access token and refresh token to User Secrets.
                            </p>
                        </div>
                    }
                    else if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger" role="alert">
                            <h4 class="alert-heading">Error</h4>
                            <p>@ViewBag.Error</p>
                        </div>
                    }
                    <a href="@Url.Action("Index", "Home")" class="btn btn-primary">Go to Home</a>
                </div>
            </div>
        </div>
    </div>
</div>
