@{
    ViewData["Title"] = "Weather Insights";
    string actType = ViewBag.ActivityType ?? "All";
    bool isWalk    = ViewBag.IsWalk == true;
    var byTemp     = (IEnumerable<(string Label, int Count, double AvgValue)>)(ViewBag.ByTemp ?? new List<(string, int, double)>());
    var inv        = System.Globalization.CultureInfo.InvariantCulture;

    string valLabel = isWalk ? "Avg pace (min/km)" : "Avg speed (km/h)";

    string FormatVal(double v) {
        if (isWalk) {
            int m = (int)v; int s = (int)Math.Round((v - m) * 60);
            return $"{m}:{s:D2} /km";
        }
        return $"{v:0.0} km/h";
    }
}

<div class="d-flex justify-content-between align-items-center mt-3 mb-3">
    <h2><i class="bi bi-thermometer-sun me-2 text-warning"></i>Weather Insights</h2>
</div>

<div class="mb-3">
    <a href="?type=Ride" class="btn btn-sm @(actType == "Ride" ? "btn-warning" : "btn-outline-secondary") me-1"><i class="bi bi-bicycle me-1"></i>Rides</a>
    <a href="?type=Walk" class="btn btn-sm @(actType == "Walk" ? "btn-success" : "btn-outline-secondary") me-1"><i class="bi bi-person-walking me-1"></i>Walks</a>
    <a href="?type=All"  class="btn btn-sm @(actType == "All"  ? "btn-primary"  : "btn-outline-secondary")"><i class="bi bi-grid me-1"></i>All</a>
    <span class="ms-3 text-muted small">Based on last @ViewBag.ActivityCount activities with GPS · @ViewBag.FetchedCount fetched</span>
</div>

@if (ViewBag.Error != null) { <div class="alert alert-danger">@ViewBag.Error</div> }

<div class="alert alert-info small">
    <i class="bi bi-info-circle me-2"></i>Weather data is fetched from <strong>Open-Meteo</strong> (free historical archive) based on GPS coordinates and activity date. First load may be slow while data is being fetched and cached.
</div>

@if (!byTemp.Any())
{
    <div class="alert alert-secondary">No weather data available yet. Try again in a moment or reload the page.</div>
}
else
{
    <!-- Best conditions summary -->
    @if (ViewBag.BestTempLabel != null)
    {
        <div class="card mb-4 border-success">
            <div class="card-header bg-success bg-opacity-25 fw-semibold">
                <i class="bi bi-stars me-2 text-warning"></i>Best Conditions Summary
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-4">
                        <div class="text-center">
                            <i class="bi bi-thermometer-half fs-2 text-warning"></i>
                            <div class="fw-bold mt-1">@ViewBag.BestTempLabel</div>
                            <div class="small text-muted">Best @(isWalk ? "pace" : "speed") temperature range (@ViewBag.BestTempCount activities)</div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="text-center">
                            <i class="bi bi-person-walking fs-2 text-success"></i>
                            <div class="fw-bold mt-1">@ViewBag.MostFreqTempLabel</div>
                            <div class="small text-muted">Most active temperature range (@ViewBag.MostFreqTempCount activities)</div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="text-center">
                            @if (ViewBag.PrefersDry == true)
                            {
                                <i class="bi bi-sun-fill fs-2 text-warning"></i>
                                <div class="fw-bold mt-1">Mainly dry</div>
                                <div class="small text-muted">@ViewBag.DryCount dry vs @ViewBag.WetCount wet activities</div>
                            }
                            else
                            {
                                <i class="bi bi-cloud-rain fs-2 text-info"></i>
                                <div class="fw-bold mt-1">Rain-or-shine</div>
                                <div class="small text-muted">@ViewBag.DryCount dry vs @ViewBag.WetCount wet activities</div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- Temperature vs performance -->
    <div class="card mb-4">
        <div class="card-header fw-semibold">
            <i class="bi bi-thermometer me-2"></i>Temperature vs @(isWalk ? "Pace" : "Speed")
        </div>
        <div class="card-body">
            <canvas id="tempChart" height="100"></canvas>
        </div>
    </div>

    <!-- Dry vs wet -->
    <div class="row g-3 mb-4">
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-header fw-semibold"><i class="bi bi-sun me-2 text-warning"></i>Dry conditions (&lt;0.5 mm precip)</div>
                <div class="card-body text-center">
                    <div class="fs-2 fw-bold">@ViewBag.DryCount <span class="fs-6 text-muted">activities</span></div>
                    @if (!isWalk)
                    {
                        <div class="text-muted">Avg speed: @ViewBag.DryAvgSpeed km/h</div>
                    }
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-header fw-semibold"><i class="bi bi-cloud-rain me-2 text-info"></i>Wet conditions (≥0.5 mm precip)</div>
                <div class="card-body text-center">
                    <div class="fs-2 fw-bold">@ViewBag.WetCount <span class="fs-6 text-muted">activities</span></div>
                    @if (!isWalk)
                    {
                        <div class="text-muted">Avg speed: @ViewBag.WetAvgSpeed km/h</div>
                        @if ((double)ViewBag.DryAvgSpeed > 0 && (double)ViewBag.WetAvgSpeed > 0)
                        {
                            double diff = (double)ViewBag.DryAvgSpeed - (double)ViewBag.WetAvgSpeed;
                            <div class="small @(diff > 0 ? "text-warning" : "text-success") mt-1">
                                @(diff > 0 ? $"You go {diff:0.0} km/h faster in dry conditions" : $"Wet weather doesn't slow you down!")
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Table breakdown -->
    <div class="card">
        <div class="card-header fw-semibold"><i class="bi bi-table me-2"></i>Full Temperature Breakdown</div>
        <div class="card-body p-0">
            <table class="table table-sm table-hover mb-0">
                <thead class="table-dark">
                    <tr><th class="ps-3">Temperature</th><th class="text-end">Activities</th><th class="text-end pe-3">@valLabel</th></tr>
                </thead>
                <tbody>
                    @foreach (var row in byTemp)
                    {
                        <tr>
                            <td class="ps-3">@row.Label</td>
                            <td class="text-end">@row.Count</td>
                            <td class="text-end pe-3">@FormatVal(row.AvgValue)</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
(function() {
    const labels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(byTemp.Select(x => x.Label).ToArray()));
    const counts = [@string.Join(",", byTemp.Select(x => x.Count))];
    const avgs   = [@string.Join(",", byTemp.Select(x => x.AvgValue.ToString("0.00", inv)))];
    const isWalk = @(isWalk ? "true" : "false");

    new Chart(document.getElementById('tempChart'), {
        data: {
            labels,
            datasets: [
                {
                    type: 'bar',
                    label: 'Activities',
                    data: counts,
                    backgroundColor: 'rgba(255,193,7,0.4)',
                    borderRadius: 4,
                    yAxisID: 'y',
                },
                {
                    type: 'line',
                    label: isWalk ? 'Avg Pace (min/km)' : 'Avg Speed (km/h)',
                    data: avgs,
                    borderColor: isWalk ? '#198754' : '#ffc107',
                    borderWidth: 2,
                    pointRadius: 5,
                    yAxisID: 'y1',
                }
            ]
        },
        options: {
            plugins: { legend: { labels: { color: '#adb5bd' } } },
            scales: {
                x: { ticks: { color: '#adb5bd' }, grid: { color: 'rgba(255,255,255,0.05)' } },
                y:  { beginAtZero: true, position: 'left',  title: { display: true, text: 'Count', color: '#adb5bd' }, ticks: { color: '#adb5bd' }, grid: { color: 'rgba(255,255,255,0.05)' } },
                y1: { beginAtZero: false, position: 'right', reverse: isWalk, title: { display: true, text: isWalk ? 'min/km' : 'km/h', color: '#adb5bd' }, ticks: { color: '#adb5bd' }, grid: { display: false } }
            }
        }
    });
})();
</script>
}
