@model ActivitiesJournal.Models.YearSummaryViewModel

@{
    ViewData["Title"] = "Yearly Summary";
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col">
            <h1 class="page-title">Summary @Model.Year</h1>
            <p class="text-muted">Overview of your Strava activities this year</p>
        </div>
    </div>

    @if (ViewBag.Error != null)
    {
        <div class="alert alert-danger" role="alert">
            <strong>Error:</strong> @ViewBag.Error
        </div>
    }

    @if (Model.Activities.Any())
    {
        <div class="row g-3 mb-4">
            <div class="col-md-4">
                <div class="card stat-card">
                    <div class="card-body">
                        <div class="stat-label">Total Distance</div>
                        <div class="stat-value">@Model.TotalDistanceKm.ToString("0.00") km</div>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card stat-card">
                    <div class="card-body">
                        <div class="stat-label">Total Moving Time</div>
                        <div class="stat-value">@Model.TotalMovingTime.ToString(@"dd\.hh\:mm")</div>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card stat-card">
                    <div class="card-body">
                        <div class="stat-label">Total Elevation Gain</div>
                        <div class="stat-value">@Model.TotalElevationGain.ToString("0") m</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row mb-4">
            <div class="col">
                <div class="card">
                    <div class="card-header">
                        <h5 class="mb-0">By Sport Type</h5>
                    </div>
                    <div class="card-body table-responsive">
                        <table class="table table-dark table-striped align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Type</th>
                                    <th class="text-end">Activities</th>
                                    <th class="text-end">Distance (km)</th>
                                    <th class="text-end">Moving Time</th>
                                    <th class="text-end">Elevation (m)</th>
                                    <th>Longest Activity</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var t in Model.ByType)
                                {
                                    <tr>
                                        <td>@t.SportType</td>
                                        <td class="text-end">@t.Count</td>
                                        <td class="text-end">@t.TotalDistanceKm.ToString("0.00")</td>
                                        <td class="text-end">@t.TotalMovingTime.ToString(@"hh\:mm")</td>
                                        <td class="text-end">@t.TotalElevationGain.ToString("0")</td>
                                        <td>
                                            @if (t.LongestByDistance != null)
                                            {
                                                <a asp-controller="Activities" asp-action="Details" asp-route-id="@t.LongestByDistance.Id" class="link-light">
                                                    @t.LongestByDistance.Name (@((t.LongestByDistance.Distance / 1000.0).ToString("0.00")) km)
                                                </a>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-info" role="alert">
            <h4 class="alert-heading">No activities for @Model.Year</h4>
            <p>We couldn't find any activities for this year. Try syncing from Strava or recording a new activity.</p>
        </div>
    }
</div>

