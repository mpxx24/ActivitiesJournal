@model ActivitiesJournal.Models.AnalysisViewModel
@using ActivitiesJournal.Models
@{
    ViewData["Title"] = "Ride Analysis";
    var typeOrder = new[] { RideType.Epic, RideType.Race, RideType.Tempo, RideType.Endurance, RideType.Recovery };
    var typeColors = new Dictionary<RideType, string>
    {
        [RideType.Recovery]  = "#6c757d",
        [RideType.Endurance] = "#17a2b8",
        [RideType.Tempo]     = "#ffc107",
        [RideType.Race]      = "#dc3545",
        [RideType.Epic]      = "#28a745",
    };
    var typeDesc = new Dictionary<RideType, string>
    {
        [RideType.Recovery]  = "< 40 km, low speed",
        [RideType.Endurance] = "40+ km, moderate speed",
        [RideType.Tempo]     = "Avg ≥ 30 km/h or 40+ km @ 28+ km/h",
        [RideType.Race]      = "50+ km @ 34+ km/h",
        [RideType.Epic]      = "130+ km",
    };
}

<div class="container-fluid">
    <div class="row mb-4 align-items-center">
        <div class="col">
            <h1 class="page-title">Ride Analysis @Model.Year</h1>
            <p class="text-muted">Ride type distribution and speed zone breakdown</p>
        </div>
        <div class="col-auto">
            <form method="get" class="d-flex gap-2 align-items-center">
                <label class="text-muted">Year:</label>
                <select name="year" class="form-select form-select-sm bg-dark text-light border-secondary" onchange="this.form.submit()">
                    @foreach (var y in Model.AvailableYears)
                    {
                        <option value="@y" selected="@(y == Model.Year)">@y</option>
                    }
                </select>
            </form>
        </div>
    </div>

    @if (ViewBag.Error != null)
    {
        <div class="alert alert-danger"><strong>Error:</strong> @ViewBag.Error</div>
    }

    <div class="row g-4 mb-4">
        <!-- Ride type summary cards -->
        <div class="col-lg-6">
            <div class="card h-100">
                <div class="card-header"><h5 class="mb-0">Ride Types</h5></div>
                <div class="card-body">
                    <div class="row g-2 mb-3">
                        @foreach (var rt in typeOrder)
                        {
                            var count = Model.TypeCounts.GetValueOrDefault(rt, 0);
                            <div class="col-6 col-md-4">
                                <div class="p-2 rounded text-center" style="border-left:4px solid @typeColors[rt]; background:rgba(255,255,255,0.03)">
                                    <div class="fw-bold" style="color:@typeColors[rt]">@rt</div>
                                    <div class="fs-4">@count</div>
                                    <div class="text-muted" style="font-size:0.7rem">@typeDesc[rt]</div>
                                </div>
                            </div>
                        }
                    </div>
                    <canvas id="typeChart" height="160"></canvas>
                </div>
            </div>
        </div>

        <!-- Speed zones -->
        <div class="col-lg-6">
            <div class="card h-100">
                <div class="card-header"><h5 class="mb-0">Speed Zones (by avg speed)</h5></div>
                <div class="card-body">
                    <canvas id="zoneChart" height="140" class="mb-3"></canvas>
                    <table class="table table-dark table-sm table-striped mb-0">
                        <thead><tr><th>Zone</th><th class="text-end">Rides</th><th class="text-end">km</th><th class="text-end">hrs</th></tr></thead>
                        <tbody>
                            @foreach (var z in Model.SpeedZones)
                            {
                                <tr>
                                    <td><span class="badge" style="background:@z.Color">@z.Label</span></td>
                                    <td class="text-end">@z.RideCount</td>
                                    <td class="text-end">@z.TotalDistanceKm.ToString("0.0")</td>
                                    <td class="text-end">@z.TotalTimeHrs.ToString("0.0")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- Classified rides list -->
    <div class="card">
        <div class="card-header"><h5 class="mb-0">All @Model.Year Rides — Classified</h5></div>
        <div class="card-body p-0">
            <table class="table table-dark table-striped table-sm mb-0">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Ride</th>
                        <th>Type</th>
                        <th class="text-end">km</th>
                        <th class="text-end">km/h</th>
                        <th class="text-end">Elev m</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in Model.ClassifiedRides)
                    {
                        <tr>
                            <td class="text-muted small">@r.Activity.StartDateLocal.ToString("MMM d")</td>
                            <td>
                                <a asp-controller="Activities" asp-action="Details" asp-route-id="@r.Activity.Id" class="link-light text-decoration-none">
                                    @r.Activity.Name
                                </a>
                            </td>
                            <td><span class="badge bg-@r.TypeColor">@r.TypeLabel</span></td>
                            <td class="text-end">@((r.Activity.Distance / 1000.0).ToString("0.0"))</td>
                            <td class="text-end">@((r.Activity.AverageSpeed * 3.6).ToString("0.1"))</td>
                            <td class="text-end">@r.Activity.TotalElevationGain.ToString("0")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
(function () {
    var typeLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(typeOrder.Select(t => t.ToString()).ToArray()));
    var typeCounts = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(typeOrder.Select(t => Model.TypeCounts.GetValueOrDefault(t, 0)).ToArray()));
    var typeColors = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(typeOrder.Select(t => typeColors[t]).ToArray()));

    new Chart(document.getElementById('typeChart'), {
        type: 'doughnut',
        data: { labels: typeLabels, datasets: [{ data: typeCounts, backgroundColor: typeColors, borderWidth: 0 }] },
        options: { plugins: { legend: { labels: { color: '#adb5bd' } } } }
    });

    var zoneLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.SpeedZones.Select(z => z.Label).ToArray()));
    var zoneCounts = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.SpeedZones.Select(z => z.RideCount).ToArray()));
    var zoneColors = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.SpeedZones.Select(z => z.Color).ToArray()));

    new Chart(document.getElementById('zoneChart'), {
        type: 'bar',
        data: { labels: zoneLabels, datasets: [{ label: 'Rides', data: zoneCounts, backgroundColor: zoneColors, borderWidth: 0 }] },
        options: {
            responsive: true,
            plugins: { legend: { display: false } },
            scales: {
                x: { ticks: { color: '#adb5bd' }, grid: { color: 'rgba(255,255,255,0.05)' } },
                y: { ticks: { color: '#adb5bd', stepSize: 1 }, grid: { color: 'rgba(255,255,255,0.05)' } }
            }
        }
    });
})();
</script>
}
