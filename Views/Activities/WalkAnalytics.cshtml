@model ActivitiesJournal.Models.WalkAnalyticsViewModel
@{
    ViewData["Title"] = "Walk Analytics";

    string FormatPace(double secPerKm)
    {
        if (secPerKm <= 0) return "—";
        int min = (int)(secPerKm / 60);
        int sec = (int)(secPerKm % 60);
        return $"{min}:{sec:D2} /km";
    }

    string FormatTime(TimeSpan ts) =>
        ts.TotalHours >= 1
            ? $"{(int)ts.TotalHours}h {ts.Minutes}m"
            : $"{ts.Minutes}m";
}

<div class="d-flex justify-content-between align-items-center mt-3 mb-3">
    <h2><i class="bi bi-person-walking me-2 text-success"></i>Walk Analytics @Model.Year</h2>
    @if (Model.AvailableYears.Any())
    {
        <div class="d-flex gap-2">
            @foreach (var y in Model.AvailableYears)
            {
                <a href="?year=@y"
                   class="btn btn-sm @(y == Model.Year ? "btn-success" : "btn-outline-secondary")">@y</a>
            }
        </div>
    }
</div>

@if (ViewBag.Error != null)
{
    <div class="alert alert-danger">@ViewBag.Error</div>
}

@if (Model.TotalWalks == 0)
{
    <div class="alert alert-info">No walks recorded for @Model.Year.</div>
}
else
{
    <!-- Streak cards (all-time) -->
    <div class="row g-3 mb-4">
        <div class="col-md-6">
            <div class="card stat-card">
                <div class="card-body">
                    <div class="d-flex align-items-center mb-1">
                        <i class="bi bi-fire fs-4 text-warning me-2"></i>
                        <div class="stat-label mb-0">Current Walking Streak</div>
                    </div>
                    <div class="stat-value">@Model.CurrentStreakDays day@(Model.CurrentStreakDays != 1 ? "s" : "")</div>
                    @if (Model.CurrentStreakDays == 0)
                    {
                        <small class="text-muted">No walk today yet</small>
                    }
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card stat-card">
                <div class="card-body">
                    <div class="d-flex align-items-center mb-1">
                        <i class="bi bi-trophy fs-4 text-warning me-2"></i>
                        <div class="stat-label mb-0">Longest Walking Streak (all-time)</div>
                    </div>
                    <div class="stat-value">@Model.LongestStreakDays day@(Model.LongestStreakDays != 1 ? "s" : "")</div>
                    @if (Model.LongestStreakDays > 0)
                    {
                        <small class="text-muted">@Model.LongestStreakStart.ToString("MMM d, yyyy") – @Model.LongestStreakEnd.ToString("MMM d, yyyy")</small>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Totals row -->
    <div class="row g-3 mb-4">
        <div class="col-6 col-md-3">
            <div class="card text-center h-100">
                <div class="card-body">
                    <div class="fs-2 fw-bold text-success">@Model.TotalWalks</div>
                    <div class="text-muted small"><i class="bi bi-person-walking me-1"></i>Total Walks</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card text-center h-100">
                <div class="card-body">
                    <div class="fs-2 fw-bold text-success">@Model.TotalDistanceKm.ToString("0.0")<span class="fs-6 text-muted"> km</span></div>
                    <div class="text-muted small"><i class="bi bi-rulers me-1"></i>Total Distance</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card text-center h-100">
                <div class="card-body">
                    <div class="fs-2 fw-bold text-success">@FormatTime(Model.TotalMovingTime)</div>
                    <div class="text-muted small"><i class="bi bi-clock me-1"></i>Total Time</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card text-center h-100">
                <div class="card-body">
                    <div class="fs-2 fw-bold text-success">@Model.TotalElevationM.ToString("0")<span class="fs-6 text-muted"> m</span></div>
                    <div class="text-muted small"><i class="bi bi-triangle me-1"></i>Total Elevation</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Averages row -->
    <div class="row g-3 mb-4">
        <div class="col-6 col-md-4">
            <div class="card text-center h-100 border-success">
                <div class="card-body">
                    <div class="fs-3 fw-bold">@Model.AvgDistanceKm.ToString("0.0") <span class="fs-6 text-muted">km</span></div>
                    <div class="text-muted small">Avg distance per walk</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-4">
            <div class="card text-center h-100 border-success">
                <div class="card-body">
                    <div class="fs-3 fw-bold">@FormatPace(Model.AvgPaceSecPerKm)</div>
                    <div class="text-muted small">Avg pace</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-4">
            <div class="card text-center h-100 border-success">
                <div class="card-body">
                    <div class="fs-3 fw-bold">@Model.AvgElevationM.ToString("0") <span class="fs-6 text-muted">m</span></div>
                    <div class="text-muted small">Avg elevation per walk</div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <!-- Personal records -->
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-header fw-semibold"><i class="bi bi-trophy me-2 text-warning"></i>Personal Records</div>
                <div class="card-body p-0">
                    <table class="table table-sm table-hover mb-0">
                        <tbody>
                            @if (Model.LongestWalk != null)
                            {
                                <tr>
                                    <td class="ps-3"><i class="bi bi-rulers me-2 text-success"></i>Longest Walk</td>
                                    <td class="fw-bold">@((Model.LongestWalk.Distance / 1000.0).ToString("0.0")) km</td>
                                    <td><a href="/Activities/Details/@Model.LongestWalk.Id" class="text-truncate d-block" style="max-width:160px">@Model.LongestWalk.Name</a></td>
                                </tr>
                            }
                            @if (Model.LongestTimeWalk != null)
                            {
                                <tr>
                                    <td class="ps-3"><i class="bi bi-clock me-2 text-success"></i>Longest Time</td>
                                    <td class="fw-bold">@FormatTime(TimeSpan.FromSeconds(Model.LongestTimeWalk.MovingTime))</td>
                                    <td><a href="/Activities/Details/@Model.LongestTimeWalk.Id" class="text-truncate d-block" style="max-width:160px">@Model.LongestTimeWalk.Name</a></td>
                                </tr>
                            }
                            @if (Model.FastestPaceWalk != null)
                            {
                                <tr>
                                    <td class="ps-3"><i class="bi bi-lightning-charge me-2 text-success"></i>Best Pace</td>
                                    <td class="fw-bold">@FormatPace(Model.FastestPaceWalk.MovingTime / (Model.FastestPaceWalk.Distance / 1000.0))</td>
                                    <td><a href="/Activities/Details/@Model.FastestPaceWalk.Id" class="text-truncate d-block" style="max-width:160px">@Model.FastestPaceWalk.Name</a></td>
                                </tr>
                            }
                            @if (Model.MostElevationWalk != null)
                            {
                                <tr>
                                    <td class="ps-3"><i class="bi bi-triangle me-2 text-success"></i>Most Elevation</td>
                                    <td class="fw-bold">@Model.MostElevationWalk.TotalElevationGain.ToString("0") m</td>
                                    <td><a href="/Activities/Details/@Model.MostElevationWalk.Id" class="text-truncate d-block" style="max-width:160px">@Model.MostElevationWalk.Name</a></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Walk length distribution -->
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-header fw-semibold"><i class="bi bi-bar-chart me-2"></i>Walk Length Distribution</div>
                <div class="card-body">
                    @{
                        int total = Model.TotalWalks;
                        int shortPct  = total > 0 ? (int)Math.Round(100.0 * Model.ShortWalks  / total) : 0;
                        int mediumPct = total > 0 ? (int)Math.Round(100.0 * Model.MediumWalks / total) : 0;
                        int longPct   = total > 0 ? (int)Math.Round(100.0 * Model.LongWalks   / total) : 0;
                    }
                    <div class="mb-3">
                        <div class="d-flex justify-content-between small mb-1">
                            <span><i class="bi bi-dash-circle me-1 text-info"></i>Short (&lt; 5 km)</span>
                            <span>@Model.ShortWalks walks (@shortPct%)</span>
                        </div>
                        <div class="progress" style="height:12px">
                            <div class="progress-bar bg-info" style="width:@shortPct%"></div>
                        </div>
                    </div>
                    <div class="mb-3">
                        <div class="d-flex justify-content-between small mb-1">
                            <span><i class="bi bi-circle me-1 text-success"></i>Medium (5–15 km)</span>
                            <span>@Model.MediumWalks walks (@mediumPct%)</span>
                        </div>
                        <div class="progress" style="height:12px">
                            <div class="progress-bar bg-success" style="width:@mediumPct%"></div>
                        </div>
                    </div>
                    <div class="mb-3">
                        <div class="d-flex justify-content-between small mb-1">
                            <span><i class="bi bi-circle-fill me-1 text-warning"></i>Long (&gt; 15 km)</span>
                            <span>@Model.LongWalks walks (@longPct%)</span>
                        </div>
                        <div class="progress" style="height:12px">
                            <div class="progress-bar bg-warning" style="width:@longPct%"></div>
                        </div>
                    </div>
                    @if (Model.WalkCount > 0 || Model.HikeCount > 0)
                    {
                        <hr class="my-2" />
                        <div class="d-flex gap-3 small text-muted">
                            <span><i class="bi bi-person-walking me-1"></i>Walks: @Model.WalkCount</span>
                            <span><i class="bi bi-tree me-1"></i>Hikes: @Model.HikeCount</span>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Monthly distance chart -->
    <div class="card mb-4">
        <div class="card-header fw-semibold"><i class="bi bi-calendar3 me-2"></i>Distance by Month</div>
        <div class="card-body">
            <canvas id="monthlyChart" height="80"></canvas>
        </div>
    </div>

    <!-- Time of day chart -->
    <div class="card mb-4">
        <div class="card-header fw-semibold"><i class="bi bi-clock me-2"></i>When Do You Walk?</div>
        <div class="card-body">
            <canvas id="hourChart" height="80"></canvas>
        </div>
    </div>

    <!-- Top 5 walks table -->
    @if (Model.Top5ByDistance.Any())
    {
        <div class="card mb-4">
            <div class="card-header fw-semibold"><i class="bi bi-list-ol me-2"></i>Top 5 Longest Walks</div>
            <div class="card-body p-0">
                <table class="table table-sm table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-3">#</th>
                            <th>Name</th>
                            <th>Date</th>
                            <th>Distance</th>
                            <th>Time</th>
                            <th>Pace</th>
                            <th>Elevation</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{ int rank = 1; }
                        @foreach (var w in Model.Top5ByDistance)
                        {
                            double distKm = w.Distance / 1000.0;
                            double paceSecKm = distKm > 0 ? w.MovingTime / distKm : 0;
                            <tr>
                                <td class="ps-3 text-muted">@rank</td>
                                <td><a href="/Activities/Details/@w.Id">@w.Name</a></td>
                                <td class="text-muted small">@w.StartDateLocal.ToString("d MMM yyyy")</td>
                                <td>@distKm.ToString("0.0") km</td>
                                <td>@FormatTime(TimeSpan.FromSeconds(w.MovingTime))</td>
                                <td>@FormatPace(paceSecKm)</td>
                                <td>@w.TotalElevationGain.ToString("0") m</td>
                            </tr>
                            rank++;
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
}

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
const monthLabels = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
const monthData   = [@string.Join(",", Enumerable.Range(1, 12).Select(m => Model.DistanceByMonth[m].ToString("0.00", System.Globalization.CultureInfo.InvariantCulture)))];

new Chart(document.getElementById('monthlyChart'), {
    type: 'bar',
    data: {
        labels: monthLabels,
        datasets: [{
            label: 'Distance (km)',
            data: monthData,
            backgroundColor: '#198754',
            borderRadius: 4,
        }]
    },
    options: {
        plugins: { legend: { display: false } },
        scales: { y: { beginAtZero: true, title: { display: true, text: 'km' } } }
    }
});

const hourLabels = Array.from({length: 24}, (_, i) => i + ':00');
const hourData   = [@string.Join(",", Model.WalksByHour)];

new Chart(document.getElementById('hourChart'), {
    type: 'bar',
    data: {
        labels: hourLabels,
        datasets: [{
            label: 'Walks started',
            data: hourData,
            backgroundColor: '#0d6efd',
            borderRadius: 4,
        }]
    },
    options: {
        plugins: { legend: { display: false } },
        scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } } }
    }
});
</script>
}
