@model List<ActivitiesJournal.Models.StravaActivity>

@{
    ViewData["Title"] = "Heatmap";
    var polylines = Model
        .Where(a => a.Map?.SummaryPolyline != null)
        .Select(a => a.Map!.SummaryPolyline!)
        .ToList();
    var encodedJson = JsonSerializer.Serialize(polylines);
    var availableYears = ViewBag.AvailableYears as List<int> ?? new List<int>();
    int? selectedYear = ViewBag.SelectedYear as int?;
}

<div class="container-fluid">
    <div class="row mb-4 align-items-center">
        <div class="col">
            <h1 class="page-title">Heatmap</h1>
            <p class="text-muted">@polylines.Count routes — @(selectedYear?.ToString() ?? "all-time")</p>
        </div>
        <div class="col-auto">
            <form method="get" class="d-flex gap-2 align-items-center">
                <label class="text-muted">Year:</label>
                <select name="year" class="form-select form-select-sm bg-dark text-light border-secondary" onchange="this.form.submit()">
                    <option value="" selected="@(selectedYear == null)">All-time</option>
                    @foreach (var y in availableYears)
                    {
                        <option value="@y" selected="@(y == selectedYear)">@y</option>
                    }
                </select>
            </form>
        </div>
    </div>

    @if (ViewBag.Error != null)
    {
        <div class="alert alert-danger" role="alert">
            <strong>Error:</strong> @ViewBag.Error
        </div>
    }

    @if (polylines.Any())
    {
        <div class="row">
            <div class="col-12">
                <div id="heatmap-map" class="heatmap-map" data-polylines='@encodedJson'></div>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-info" role="alert">
            <h4 class="alert-heading">No routes to show</h4>
            <p>We couldn't find any activities with route data for this year.</p>
        </div>
    }
</div>

