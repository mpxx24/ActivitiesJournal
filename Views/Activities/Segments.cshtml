@model ActivitiesJournal.Models.SegmentsViewModel
@{
    ViewData["Title"] = "Segments & Best Efforts";
    var beVm = ViewBag.BestEfforts as ActivitiesJournal.Models.BestEffortsViewModel;
    int fetchCount = ViewBag.FetchCount ?? 30;
}

<div class="container-fluid">
    <div class="row mb-4 align-items-center">
        <div class="col">
            <h1 class="page-title">Segments & Best Efforts</h1>
            <p class="text-muted">Based on your last @Model.RidesFetched rides (of @Model.TotalRidesAvailable total)</p>
        </div>
        <div class="col-auto">
            <form method="get" class="d-flex gap-2 align-items-center">
                <label class="text-muted">Rides to scan:</label>
                <select name="count" class="form-select form-select-sm bg-dark text-light border-secondary" onchange="this.form.submit()">
                    @foreach (var n in new[] { 10, 20, 30, 50, 100 })
                    {
                        <option value="@n" selected="@(n == fetchCount)">@n</option>
                    }
                </select>
            </form>
        </div>
    </div>

    @if (ViewBag.Error != null)
    {
        <div class="alert alert-danger"><strong>Error:</strong> @ViewBag.Error</div>
    }

    <div class="alert alert-secondary small">
        <i class="bi bi-info-circle me-1"></i>
        Each scan fetches full activity details from the Strava API (1 request per ride). Larger counts may be slower.
        Increasing the count reveals more segment history but Strava may rate-limit above ~100 requests/15 min.
    </div>

    <!-- Best Efforts Over Time -->
    @if (beVm?.Rows.Any() == true)
    {
        <div class="card mb-4">
            <div class="card-header"><h5 class="mb-0"><i class="bi bi-stopwatch text-warning me-2"></i>Best Efforts Over Time (#4)</h5></div>
            <div class="card-body p-0">
                <table class="table table-dark table-striped table-sm mb-0">
                    <thead>
                        <tr>
                            <th>Distance</th>
                            <th class="text-end">Best Time</th>
                            <th class="text-end">Date</th>
                            <th>Ride</th>
                            <th class="text-end">Attempts in window</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in beVm.Rows)
                        {
                            <tr>
                                <td class="fw-semibold">@row.DistanceName</td>
                                <td class="text-end text-warning">@TimeSpan.FromSeconds(row.BestElapsedSeconds).ToString(@"m\:ss")</td>
                                <td class="text-end text-muted small">@row.BestDate.ToString("MMM d, yyyy")</td>
                                <td>
                                    <a asp-controller="Activities" asp-action="Details" asp-route-id="@row.BestActivityId" class="link-light text-decoration-none small">
                                        @row.BestActivityName
                                    </a>
                                </td>
                                <td class="text-end text-muted">@row.History.Count</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

    <!-- Segment Leaderboard -->
    @if (Model.Segments.Any())
    {
        <!-- Floating map popup for segment hover -->
        <div id="seg-map-popup" style="display:none;position:fixed;z-index:9999;width:260px;height:180px;border-radius:8px;overflow:hidden;box-shadow:0 4px 20px rgba(0,0,0,.6);pointer-events:none;"></div>

        <div class="card">
            <div class="card-header"><h5 class="mb-0"><i class="bi bi-flag text-warning me-2"></i>Your Segment Leaderboard (#5)</h5></div>
            <div class="card-body p-0">
                <table class="table table-dark table-striped table-sm mb-0">
                    <thead>
                        <tr>
                            <th>Segment</th>
                            <th class="text-end">Dist</th>
                            <th class="text-end">Grade</th>
                            <th class="text-end">Best Time</th>
                            <th class="text-end">PR Rank</th>
                            <th class="text-end">Attempts</th>
                            <th class="text-end">Best Date</th>
                            <th>Best Ride</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var seg in Model.Segments)
                        {
                            var hasMap = seg.StartLat.HasValue && seg.StartLng.HasValue;
                            <tr class="@(hasMap ? "seg-row" : "")"
                                @if (hasMap)
                                {
                                    @:data-slat="@seg.StartLat!.Value.ToString("F6", System.Globalization.CultureInfo.InvariantCulture)"
                                    @:data-slng="@seg.StartLng!.Value.ToString("F6", System.Globalization.CultureInfo.InvariantCulture)"
                                    @:data-elat="@(seg.EndLat.HasValue ? seg.EndLat.Value.ToString("F6", System.Globalization.CultureInfo.InvariantCulture) : "")"
                                    @:data-elng="@(seg.EndLng.HasValue ? seg.EndLng.Value.ToString("F6", System.Globalization.CultureInfo.InvariantCulture) : "")"
                                    if (!string.IsNullOrEmpty(seg.Polyline))
                                    {
                                        @:data-polyline="@Html.Raw(System.Text.Json.JsonSerializer.Serialize(seg.Polyline))"
                                    }
                                }>
                                <td>@seg.SegmentName</td>
                                <td class="text-end text-muted small">@((seg.DistanceM / 1000.0).ToString("0.0")) km</td>
                                <td class="text-end text-muted small">@seg.AverageGrade.ToString("0.1")%</td>
                                <td class="text-end text-warning">@TimeSpan.FromSeconds(seg.BestElapsedSeconds).ToString(@"m\:ss")</td>
                                <td class="text-end">
                                    @if (seg.BestPrRank.HasValue)
                                    {
                                        <span class="badge bg-success">PR #@seg.BestPrRank</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">—</span>
                                    }
                                </td>
                                <td class="text-end @(seg.AttemptCount > 1 ? "text-info" : "text-muted")">@seg.AttemptCount</td>
                                <td class="text-end text-muted small">@seg.BestDate.ToString("MMM d, yy")</td>
                                <td>
                                    <a asp-controller="Activities" asp-action="Details" asp-route-id="@seg.BestActivityId" class="link-light text-decoration-none small">
                                        @seg.BestActivityName
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
        <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
        <script>
        (function () {
            const popup = document.getElementById('seg-map-popup');
            let map = null;

            function initMap() {
                if (map) return;
                map = L.map(popup, { zoomControl: false, attributionControl: false });
                L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
                    maxZoom: 18
                }).addTo(map);
            }

            // Decode Google encoded polyline format
            function decodePolyline(encoded) {
                const pts = [];
                let i = 0, lat = 0, lng = 0;
                while (i < encoded.length) {
                    let b, shift = 0, result = 0;
                    do { b = encoded.charCodeAt(i++) - 63; result |= (b & 0x1f) << shift; shift += 5; } while (b >= 0x20);
                    lat += (result & 1) ? ~(result >> 1) : (result >> 1);
                    shift = 0; result = 0;
                    do { b = encoded.charCodeAt(i++) - 63; result |= (b & 0x1f) << shift; shift += 5; } while (b >= 0x20);
                    lng += (result & 1) ? ~(result >> 1) : (result >> 1);
                    pts.push([lat / 1e5, lng / 1e5]);
                }
                return pts;
            }

            let startMarker = null, endMarker = null, line = null;

            function showSegment(row) {
                const slat = parseFloat(row.dataset.slat);
                const slng = parseFloat(row.dataset.slng);
                const elat = row.dataset.elat ? parseFloat(row.dataset.elat) : null;
                const elng = row.dataset.elng ? parseFloat(row.dataset.elng) : null;
                const encodedPoly = row.dataset.polyline ? JSON.parse(row.dataset.polyline) : null;

                initMap();

                // Clear previous
                if (startMarker) { startMarker.remove(); startMarker = null; }
                if (endMarker)   { endMarker.remove();   endMarker = null; }
                if (line)        { line.remove();         line = null; }

                startMarker = L.circleMarker([slat, slng], { radius: 7, color: '#22c55e', fillColor: '#22c55e', fillOpacity: 1, weight: 2 }).addTo(map);

                if (encodedPoly) {
                    const pts = decodePolyline(encodedPoly);
                    line = L.polyline(pts, { color: '#facc15', weight: 3, opacity: 0.9 }).addTo(map);
                    if (elat !== null && elng !== null)
                        endMarker = L.circleMarker([elat, elng], { radius: 7, color: '#ef4444', fillColor: '#ef4444', fillOpacity: 1, weight: 2 }).addTo(map);
                    map.fitBounds(line.getBounds(), { padding: [16, 16] });
                } else {
                    const pts = [[slat, slng]];
                    if (elat !== null && elng !== null) {
                        endMarker = L.circleMarker([elat, elng], { radius: 7, color: '#ef4444', fillColor: '#ef4444', fillOpacity: 1, weight: 2 }).addTo(map);
                        pts.push([elat, elng]);
                        line = L.polyline(pts, { color: '#facc15', weight: 3, opacity: 0.8, dashArray: '6 4' }).addTo(map);
                        map.fitBounds(L.latLngBounds(pts), { padding: [20, 20] });
                    } else {
                        map.setView([slat, slng], 14);
                    }
                }
                map.invalidateSize();
            }

            document.querySelectorAll('tr.seg-row').forEach(row => {
                row.addEventListener('mouseenter', function (e) {
                    popup.style.display = 'block';
                    positionPopup(e);
                    showSegment(row);
                });
                row.addEventListener('mousemove', positionPopup);
                row.addEventListener('mouseleave', function () {
                    popup.style.display = 'none';
                });
            });

            function positionPopup(e) {
                const gap = 16;
                let x = e.clientX + gap;
                let y = e.clientY + gap;
                if (x + 260 > window.innerWidth)  x = e.clientX - 260 - gap;
                if (y + 180 > window.innerHeight) y = e.clientY - 180 - gap;
                popup.style.left = x + 'px';
                popup.style.top  = y + 'px';
            }
        })();
        </script>
    }
    else if (ViewBag.Error == null)
    {
        <div class="alert alert-info">No segment data found in the scanned rides.</div>
    }
</div>
