@{
    ViewData["Title"] = $"{ViewBag.SelectedYear} Year in Review";
    int yr = ViewBag.SelectedYear ?? DateTime.Now.Year;
    var availableYears = ViewBag.AvailableYears as List<int> ?? new();
    var monthlyKm = ViewBag.MonthlyKm as List<double> ?? new();
    string[] monthNames = { "Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec" };
}

<div class="d-flex justify-content-between align-items-center mt-3 mb-2 no-print">
    <h2><i class="bi bi-stars me-2 text-warning"></i>Year in Review</h2>
    <div class="d-flex gap-2 align-items-center">
        <form method="get" class="d-flex gap-2 align-items-center">
            <select name="year" class="form-select form-select-sm bg-dark text-light border-secondary" onchange="this.form.submit()">
                @foreach (var y in availableYears)
                {
                    <option value="@y" selected="@(y == yr)">@y</option>
                }
            </select>
        </form>
        <button onclick="window.print()" class="btn btn-sm btn-outline-secondary"><i class="bi bi-printer me-1"></i>Print / Save</button>
    </div>
</div>

@if (ViewBag.Error != null) { <div class="alert alert-danger">@ViewBag.Error</div> }

<!-- Printable card -->
<div class="review-card p-4 rounded" style="background:linear-gradient(135deg,#0f172a 0%,#1e3a5f 50%,#0f172a 100%);color:#e5e7eb;max-width:900px;margin:0 auto;">

    <!-- Header -->
    <div class="text-center mb-4">
        <div class="display-5 fw-bold text-warning">@yr</div>
        <div class="fs-4 text-light opacity-75">Year in Review</div>
        <div class="text-muted small mt-1"><i class="bi bi-bicycle me-1"></i>Cycling &amp; Walking Summary</div>
    </div>

    <!-- Big numbers row -->
    <div class="row g-3 mb-4 text-center">
        <div class="col-6 col-md-3">
            <div style="font-size:2.5rem;font-weight:700;color:#fdc525">@(((double)(ViewBag.RideKm ?? 0.0)).ToString("0"))</div>
            <div class="small text-muted">km ridden</div>
        </div>
        <div class="col-6 col-md-3">
            <div style="font-size:2.5rem;font-weight:700;color:#fd7e14">@ViewBag.RideCount</div>
            <div class="small text-muted">rides</div>
        </div>
        <div class="col-6 col-md-3">
            <div style="font-size:2.5rem;font-weight:700;color:#22c55e">@ViewBag.RideElevM</div>
            <div class="small text-muted">m climbed</div>
        </div>
        <div class="col-6 col-md-3">
            <div style="font-size:2.5rem;font-weight:700;color:#38bdf8">@(((double)(ViewBag.RideHours ?? 0.0)).ToString("0.0"))</div>
            <div class="small text-muted">hours in the saddle</div>
        </div>
    </div>

    <hr style="border-color:rgba(255,255,255,0.1)" />

    <!-- Highlights -->
    <div class="row g-3 mb-4">
        <div class="col-12">
            <div class="small text-muted text-uppercase fw-semibold mb-2" style="letter-spacing:.08em">Ride Highlights</div>
        </div>
        <div class="col-md-4">
            <div class="p-3 rounded" style="background:rgba(255,255,255,0.05)">
                <div class="small text-muted mb-1"><i class="bi bi-arrow-right-circle me-1"></i>Longest Ride</div>
                <div class="fw-bold fs-5 text-warning">@ViewBag.LongestRide</div>
                <div class="small text-muted text-truncate">@ViewBag.LongestRideName</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="p-3 rounded" style="background:rgba(255,255,255,0.05)">
                <div class="small text-muted mb-1"><i class="bi bi-lightning me-1"></i>Fastest Avg (20km+)</div>
                <div class="fw-bold fs-5 text-info">@ViewBag.FastestRide</div>
                <div class="small text-muted text-truncate">@ViewBag.FastestRideName</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="p-3 rounded" style="background:rgba(255,255,255,0.05)">
                <div class="small text-muted mb-1"><i class="bi bi-triangle me-1"></i>Most Elevation</div>
                <div class="fw-bold fs-5 text-success">@ViewBag.MostElevRide</div>
                <div class="small text-muted text-truncate">@ViewBag.MostElevRideName</div>
            </div>
        </div>
    </div>

    <!-- Streak & misc stats -->
    <div class="row g-3 mb-4 text-center">
        <div class="col-4">
            <div class="fw-bold fs-4" style="color:#fd7e14">@ViewBag.BestStreak</div>
            <div class="small text-muted">day streak</div>
        </div>
        <div class="col-4">
            <div class="fw-bold fs-4 text-success">@ViewBag.ActiveMonths / 12</div>
            <div class="small text-muted">active months</div>
        </div>
        <div class="col-4">
            <div class="fw-bold fs-4 text-info">@ViewBag.BiggestMonthKm km</div>
            <div class="small text-muted">best month (@ViewBag.BiggestMonth)</div>
        </div>
    </div>

    @if ((int)(ViewBag.WalkCount ?? 0) > 0)
    {
        <hr style="border-color:rgba(255,255,255,0.1)" />
        <div class="row g-3 mb-4 text-center">
            <div class="col-12">
                <div class="small text-muted text-uppercase fw-semibold mb-2" style="letter-spacing:.08em">Also walked</div>
            </div>
            <div class="col-6">
                <div class="fw-bold fs-4 text-success">@(((double)(ViewBag.WalkKm ?? 0.0)).ToString("0")) km</div>
                <div class="small text-muted">total walked</div>
            </div>
            <div class="col-6">
                <div class="fw-bold fs-4 text-success">@ViewBag.WalkCount</div>
                <div class="small text-muted">walks &amp; hikes</div>
            </div>
        </div>
    }

    <!-- Monthly bar chart -->
    <hr style="border-color:rgba(255,255,255,0.1)" />
    <div class="mb-2 small text-muted text-uppercase fw-semibold" style="letter-spacing:.08em">Monthly Ride Distance</div>
    <canvas id="reviewChart" height="70"></canvas>

    <div class="text-center mt-4 small" style="color:rgba(255,255,255,0.3)">
        Activities Journal &middot; Powered by Strava
    </div>
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
(function () {
    var labels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(monthNames));
    var data = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(monthlyKm));
    new Chart(document.getElementById("reviewChart"), {
        type: "bar",
        data: {
            labels: labels,
            datasets: [{ data: data, backgroundColor: "rgba(253,197,37,0.8)", borderColor: "#fdc525", borderWidth: 1 }]
        },
        options: {
            responsive: true,
            plugins: { legend: { display: false }, tooltip: { callbacks: { label: ctx => ctx.parsed.y.toFixed(1) + " km" } } },
            scales: {
                x: { ticks: { color: "#9ca3af" }, grid: { display: false } },
                y: { ticks: { color: "#9ca3af", callback: v => v + " km" }, grid: { color: "rgba(255,255,255,0.05)" } }
            }
        }
    });
})();
</script>
}

<style>
@@media print {
  .no-print { display: none !important; }
  header, footer, .app-navbar { display: none !important; }
  body, .app-body { background: transparent !important; margin: 0 !important; }
  .container { padding: 0 !important; max-width: 100% !important; }
  .review-card {
    max-width: 100% !important;
    page-break-inside: avoid;
    -webkit-print-color-adjust: exact;
    print-color-adjust: exact;
  }
}
</style>
