@using ActivitiesJournal.Models
@{
    ViewData["Title"] = "Dashboard";
    var recent = ViewBag.Recent as List<StravaActivity> ?? new();
    var weeklyKm = ViewBag.WeeklyKm as List<double> ?? new();

    string SportIcon(string sport) => sport switch {
        "Walk" or "Hike" or "VirtualWalk" => "bi-person-walking",
        "Ride" or "VirtualRide" or "GravelRide" or "MountainBikeRide" => "bi-bicycle",
        _ => "bi-activity"
    };
    string FormatDuration(int secs) {
        int h = secs / 3600; int m = (secs % 3600) / 60;
        return h > 0 ? $"{h}h {m}m" : $"{m}m";
    }
}

<div class="mt-3 mb-4" data-streak="@ViewBag.RideStreak">
    <h2><i class="bi bi-speedometer2 me-2 text-warning"></i>Dashboard</h2>
    <p class="text-muted">Your activity overview at a glance.</p>
</div>

<!-- This week -->
<div class="row g-3 mb-4">
    <div class="col-12">
        <h6 class="text-muted text-uppercase small fw-semibold mb-2">This Week</h6>
    </div>
    <div class="col-6 col-md-3">
        <div class="card bg-dark border-secondary text-center">
            <div class="card-body py-3">
                <div class="text-muted small mb-1"><i class="bi bi-bicycle me-1"></i>Ride km</div>
                <div class="fw-bold fs-4 text-warning">@(((double)(ViewBag.WeekRideKm ?? 0.0)).ToString("0.0"))</div>
                <div class="text-muted small">@ViewBag.WeekRideCount ride@(ViewBag.WeekRideCount != 1 ? "s" : "")</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card bg-dark border-secondary text-center">
            <div class="card-body py-3">
                <div class="text-muted small mb-1"><i class="bi bi-person-walking me-1"></i>Walk km</div>
                <div class="fw-bold fs-4 text-success">@(((double)(ViewBag.WeekWalkKm ?? 0.0)).ToString("0.0"))</div>
                <div class="text-muted small">@ViewBag.WeekWalkCount walk@(ViewBag.WeekWalkCount != 1 ? "s" : "")</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card bg-dark border-secondary text-center">
            <div class="card-body py-3">
                <div class="text-muted small mb-1"><i class="bi bi-fire me-1"></i>Ride Streak</div>
                <div class="fw-bold fs-4 @(ViewBag.RideStreak > 0 ? "text-orange" : "text-muted")" style="color:@(ViewBag.RideStreak > 0 ? "#fd7e14" : "")">@ViewBag.RideStreak</div>
                <div class="text-muted small">day@(ViewBag.RideStreak != 1 ? "s" : "")</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card bg-dark border-secondary text-center">
            <div class="card-body py-3">
                <div class="text-muted small mb-1"><i class="bi bi-calendar-check me-1"></i>YTD Rides</div>
                <div class="fw-bold fs-4">@(((double)(ViewBag.YtdRideKm ?? 0.0)).ToString("0"))<span class="fs-6"> km</span></div>
                <div class="text-muted small">@ViewBag.YtdRideCount activities</div>
            </div>
        </div>
    </div>
</div>

<!-- Mini sparkline -->
@if (weeklyKm.Any())
{
    <div class="card bg-dark border-secondary mb-4">
        <div class="card-header border-secondary fw-semibold small">
            <i class="bi bi-graph-up me-1 text-warning"></i>Weekly distance — last 8 weeks
        </div>
        <div class="card-body py-2">
            <canvas id="sparkChart" height="55"></canvas>
        </div>
    </div>
}

<!-- Recent activities -->
<div class="card bg-dark border-secondary">
    <div class="card-header border-secondary d-flex justify-content-between align-items-center">
        <span class="fw-semibold"><i class="bi bi-list-ul me-1 text-warning"></i>Recent Activities</span>
        <a href="/Activities" class="btn btn-sm btn-outline-secondary">View all</a>
    </div>
    <div class="list-group list-group-flush">
        @if (!recent.Any())
        {
            <div class="list-group-item bg-dark text-muted text-center py-3">
                No activities yet. <a href="/Strava/Authorize">Connect Strava</a> to get started.
            </div>
        }
        @foreach (var a in recent)
        {
            double distKm = a.Distance / 1000.0;
            bool walk = a.SportType is "Walk" or "Hike" or "VirtualWalk";
            string speedOrPace = walk && distKm > 0
                ? $"{(int)(a.MovingTime / 60.0 / distKm)}:{(int)Math.Round(((a.MovingTime / 60.0 / distKm) - (int)(a.MovingTime / 60.0 / distKm)) * 60):D2}/km"
                : $"{(a.AverageSpeed * 3.6):0.0} km/h";
            <a href="/Activities/Details/@a.Id" class="list-group-item list-group-item-action bg-dark border-secondary py-2">
                <div class="d-flex align-items-center gap-3">
                    <i class="bi @SportIcon(a.SportType) text-warning fs-5" style="min-width:20px"></i>
                    <div class="flex-grow-1 text-truncate">
                        <div class="fw-semibold text-truncate">@a.Name</div>
                        <div class="text-muted small">@a.StartDateLocal.ToString("ddd d MMM yyyy")</div>
                    </div>
                    <div class="text-end text-nowrap">
                        <div class="fw-semibold">@distKm.ToString("0.0") km</div>
                        <div class="text-muted small">@FormatDuration(a.MovingTime) &middot; @speedOrPace</div>
                    </div>
                </div>
            </a>
        }
    </div>
</div>

<!-- Quick links -->
<div class="row g-2 mt-3">
    <div class="col-12">
        <h6 class="text-muted text-uppercase small fw-semibold mb-2">Quick Links</h6>
    </div>
    @{
        var links = new[] {
            ("/Activities/Heatmap", "bi-map", "Heatmap", "btn-outline-secondary"),
            ("/Activities/PersonalRecords", "bi-trophy", "Records", "btn-outline-secondary"),
            ("/Activities/Calendar", "bi-calendar3", "Calendar", "btn-outline-secondary"),
            ("/Activities/Fitness", "bi-heart-pulse", "Fitness", "btn-outline-secondary"),
            ("/Activities/ThisTimeLastYear", "bi-clock-history", "Last Year", "btn-outline-secondary"),
            ("/Activities/WalkAnalytics", "bi-person-walking", "Walking", "btn-outline-secondary"),
        };
    }
    @foreach (var (url, icon, label, cls) in links)
    {
        <div class="col-6 col-md-2">
            <a href="@url" class="btn @cls btn-sm w-100"><i class="bi @icon me-1"></i>@label</a>
        </div>
    }
</div>

@section Scripts {
@if (weeklyKm.Any())
{
<script>
(function () {
    var data = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(weeklyKm.Select(k => Math.Round(k, 1)).ToList()));
    var labels = data.map((_, i) => { var w = @(weeklyKm.Count) - 1 - i; return w === 0 ? "This week" : w + "w ago"; });
    new Chart(document.getElementById("sparkChart"), {
        type: "bar",
        data: {
            labels: labels,
            datasets: [{ data: data, backgroundColor: "rgba(253,197,37,0.7)", borderColor: "#fdc525", borderWidth: 1 }]
        },
        options: {
            responsive: true,
            plugins: { legend: { display: false }, tooltip: { callbacks: { label: ctx => ctx.parsed.y.toFixed(1) + " km" } } },
            scales: {
                x: { ticks: { color: "#adb5bd", font: { size: 11 } }, grid: { display: false } },
                y: { ticks: { color: "#adb5bd", callback: v => v + " km", font: { size: 11 } }, grid: { color: "#343a40" } }
            }
        }
    });
})();
</script>
}
}
