@inject IOptions<ActivitiesJournal.Models.StravaConfig> StravaOptions
@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
    bool isCyclingSection = currentController == "Goals"
        || (currentController == "Activities" && currentAction is
            "PersonalRecords" or "MonthComparison" or "DayInHistory" or
            "Calendar" or "Badges" or "Analysis" or "Fitness" or "Segments" or "Timeline" or "SpeedTrend" or "Histogram" or "NameAnalysis" or "CumulativeDistance" or "WeatherInsights");
    bool isWalkingSection = currentController == "Activities" && currentAction == "WalkAnalytics";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ActivitiesJournal</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" crossorigin="" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ActivitiesJournal.styles.css" asp-append-version="true" />
</head>
<body class="app-body">
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark bg-dark shadow-sm app-navbar">
            <div class="container-fluid">
                <a class="navbar-brand fw-semibold" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-activity me-1 text-warning"></i>Activities Journal
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-house-door me-1"></i> Home
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Activities" asp-action="Index">
                                <i class="bi bi-list-ul me-1"></i> Activities
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Activities" asp-action="Summary">
                                <i class="bi bi-graph-up-arrow me-1"></i> Summary
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Activities" asp-action="Heatmap">
                                <i class="bi bi-map me-1"></i> Heatmap
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(isWalkingSection ? "active" : "")" asp-area="" asp-controller="Activities" asp-action="WalkAnalytics">
                                <i class="bi bi-person-walking me-1"></i> Walking
                            </a>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle @(isCyclingSection ? "active" : "")"
                               href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="bi bi-bicycle me-1"></i> Cycling
                            </a>
                            <ul class="dropdown-menu dropdown-menu-dark">
                                <li><h6 class="dropdown-header text-muted">Performance</h6></li>
                                <li>
                                    <a class="dropdown-item" asp-controller="Activities" asp-action="Histogram">
                                        <i class="bi bi-bar-chart-steps me-2"></i>Distribution
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-controller="Activities" asp-action="NameAnalysis">
                                        <i class="bi bi-chat-quote me-2"></i>Name Analysis
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-controller="Activities" asp-action="SpeedTrend">
                                        <i class="bi bi-graph-up-arrow me-2"></i>Speed / Pace Trend
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-controller="Activities" asp-action="PersonalRecords">
                                        <i class="bi bi-trophy me-2"></i>Records
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-controller="Activities" asp-action="Fitness">
                                        <i class="bi bi-heart-pulse me-2"></i>Fitness (CTL/ATL)
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-controller="Activities" asp-action="WeatherInsights">
                                        <i class="bi bi-thermometer-sun me-2"></i>Weather Insights
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-controller="Activities" asp-action="Analysis">
                                        <i class="bi bi-pie-chart me-2"></i>Analysis
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-controller="Activities" asp-action="Segments">
                                        <i class="bi bi-flag me-2"></i>Segments
                                    </a>
                                </li>
                                <li><hr class="dropdown-divider" /></li>
                                <li><h6 class="dropdown-header text-muted">History</h6></li>
                                <li>
                                    <a class="dropdown-item" asp-controller="Activities" asp-action="CumulativeDistance">
                                        <i class="bi bi-graph-up me-2"></i>Cumulative Distance
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-controller="Activities" asp-action="Timeline">
                                        <i class="bi bi-bar-chart-line me-2"></i>Timeline
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-controller="Activities" asp-action="MonthComparison">
                                        <i class="bi bi-bar-chart me-2"></i>Month vs Month
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-controller="Activities" asp-action="Calendar">
                                        <i class="bi bi-calendar3 me-2"></i>Calendar
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-controller="Activities" asp-action="DayInHistory">
                                        <i class="bi bi-calendar-event me-2"></i>On This Day
                                    </a>
                                </li>
                                <li><hr class="dropdown-divider" /></li>
                                <li><h6 class="dropdown-header text-muted">Goals</h6></li>
                                <li>
                                    <a class="dropdown-item" asp-controller="Goals" asp-action="Index">
                                        <i class="bi bi-bullseye me-2"></i>Goals &amp; Challenges
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-controller="Activities" asp-action="Badges">
                                        <i class="bi bi-award me-2"></i>Badges
                                    </a>
                                </li>
                            </ul>
                        </li>
                        <li class="nav-item ms-sm-auto">
                            <form method="post" asp-controller="Strava" asp-action="ClearCache"
                                  asp-route-returnUrl="@Context.Request.Path">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="nav-link btn btn-link text-muted"
                                        title="Clear cached Strava data and reload from API">
                                    <i class="bi bi-arrow-clockwise me-1"></i>Reload
                                </button>
                            </form>
                        </li>
                        @if (string.IsNullOrEmpty(StravaOptions.Value.AccessToken))
                        {
                            <li class="nav-item ms-sm-auto">
                                <a class="nav-link text-warning" asp-area="" asp-controller="Strava" asp-action="Authorize">
                                    <i class="bi bi-link-45deg me-1"></i> Connect Strava
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - ActivitiesJournal - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" crossorigin=""></script>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
