@inject Microsoft.Extensions.Options.IOptions<ActivitiesJournal.Models.StravaConfig> StravaOptions
@inject ActivitiesJournal.Services.IStravaService StravaServiceLayout
@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var cacheTs = StravaServiceLayout.GetCacheTimestamp();
    string cacheAge = cacheTs == null ? "not loaded"
        : (DateTime.Now - cacheTs.Value).TotalMinutes < 1 ? "just now"
        : (DateTime.Now - cacheTs.Value).TotalMinutes < 60 ? $"{(int)(DateTime.Now - cacheTs.Value).TotalMinutes}m ago"
        : $"{(int)(DateTime.Now - cacheTs.Value).TotalHours}h ago";
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();

    Func<string, string?, string> NavClass = (ctrl, act) => {
        bool active = act != null
            ? currentController == ctrl && currentAction == act
            : currentController == ctrl;
        return "sidebar-link" + (active ? " active" : "");
    };
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ActivitiesJournal</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" crossorigin="" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ActivitiesJournal.styles.css" asp-append-version="true" />
</head>
<body class="app-body">

<!-- Mobile top bar (visible only below md breakpoint) -->
<nav class="app-topbar d-flex d-md-none align-items-center px-3 gap-2">
    <button class="btn btn-link text-light p-1" type="button"
            data-bs-toggle="offcanvas" data-bs-target="#appSidebar" aria-label="Toggle navigation">
        <i class="bi bi-list fs-4"></i>
    </button>
    <a class="text-decoration-none text-light fw-semibold d-flex align-items-center gap-1"
       asp-controller="Home" asp-action="Index">
        <i class="bi bi-activity text-warning"></i>Activities Journal
    </a>
</nav>

<!-- Layout wrapper: sidebar + content side by side -->
<div class="d-flex app-wrapper">

    <!-- Sidebar: offcanvas on mobile, inline on md+ -->
    <div class="offcanvas offcanvas-start offcanvas-md app-sidebar" tabindex="-1" id="appSidebar">
        <!-- Mobile header (hidden on desktop) -->
        <div class="offcanvas-header d-md-none border-bottom" style="border-color: rgba(48,54,61,0.8) !important">
            <span class="fw-semibold text-light">
                <i class="bi bi-activity me-1 text-warning"></i>Activities Journal
            </span>
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas" aria-label="Close"></button>
        </div>

        <div class="offcanvas-body d-flex flex-column p-0">
            <!-- Brand (desktop only) -->
            <div class="sidebar-brand d-none d-md-flex align-items-center">
                <a class="text-decoration-none d-flex align-items-center gap-2"
                   asp-controller="Home" asp-action="Index">
                    <i class="bi bi-activity text-warning fs-5"></i>
                    <span class="fw-semibold text-light">Activities Journal</span>
                </a>
            </div>

            <!-- Nav links -->
            <nav class="sidebar-nav flex-grow-1 overflow-y-auto">

                <div class="sidebar-section-label">General</div>
                <a class="@NavClass("Home", "Index")" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-house-door"></i>Home
                </a>
                <a class="@NavClass("Activities", "Index")" asp-controller="Activities" asp-action="Index">
                    <i class="bi bi-list-ul"></i>Activities
                </a>
                <a class="@NavClass("Activities", "Summary")" asp-controller="Activities" asp-action="Summary">
                    <i class="bi bi-graph-up-arrow"></i>Summary
                </a>
                <a class="@NavClass("Export", null)" asp-controller="Export" asp-action="Index">
                    <i class="bi bi-download"></i>Export
                </a>

                <div class="sidebar-section-label">Analytics</div>
                <a class="@NavClass("Activities", "WalkAnalytics")" asp-controller="Activities" asp-action="WalkAnalytics">
                    <i class="bi bi-person-walking"></i>Walking
                </a>
                <a class="@NavClass("Activities", "Histogram")" asp-controller="Activities" asp-action="Histogram">
                    <i class="bi bi-bar-chart-steps"></i>Distribution
                </a>
                <a class="@NavClass("Activities", "SpeedTrend")" asp-controller="Activities" asp-action="SpeedTrend">
                    <i class="bi bi-graph-up-arrow"></i>Speed / Pace
                </a>
                <a class="@NavClass("Activities", "CadenceTrend")" asp-controller="Activities" asp-action="CadenceTrend">
                    <i class="bi bi-arrow-repeat"></i>Cadence
                </a>
                <a class="@NavClass("Activities", "PersonalRecords")" asp-controller="Activities" asp-action="PersonalRecords">
                    <i class="bi bi-trophy"></i>Records
                </a>
                <a class="@NavClass("Activities", "Fitness")" asp-controller="Activities" asp-action="Fitness">
                    <i class="bi bi-heart-pulse"></i>Fitness
                </a>
                <a class="@NavClass("Activities", "ActiveMinutes")" asp-controller="Activities" asp-action="ActiveMinutes">
                    <i class="bi bi-stopwatch"></i>Active Minutes
                </a>
                <a class="@NavClass("Activities", "WeatherInsights")" asp-controller="Activities" asp-action="WeatherInsights">
                    <i class="bi bi-thermometer-sun"></i>Weather
                </a>
                <a class="@NavClass("Activities", "Analysis")" asp-controller="Activities" asp-action="Analysis">
                    <i class="bi bi-pie-chart"></i>Analysis
                </a>
                <a class="@NavClass("Activities", "Segments")" asp-controller="Activities" asp-action="Segments">
                    <i class="bi bi-flag"></i>Segments
                </a>
                <a class="@NavClass("Activities", "NameAnalysis")" asp-controller="Activities" asp-action="NameAnalysis">
                    <i class="bi bi-chat-quote"></i>Name Analysis
                </a>

                <div class="sidebar-section-label">History</div>
                <a class="@NavClass("Activities", "RouteLibrary")" asp-controller="Activities" asp-action="RouteLibrary">
                    <i class="bi bi-signpost-2"></i>Route Library
                </a>
                <a class="@NavClass("Activities", "LongestRide")" asp-controller="Activities" asp-action="LongestRide">
                    <i class="bi bi-trophy-fill"></i>Longest Ride
                </a>
                <a class="@NavClass("Activities", "CumulativeDistance")" asp-controller="Activities" asp-action="CumulativeDistance">
                    <i class="bi bi-graph-up"></i>Cumulative Distance
                </a>
                <a class="@NavClass("Activities", "Timeline")" asp-controller="Activities" asp-action="Timeline">
                    <i class="bi bi-bar-chart-line"></i>Timeline
                </a>
                <a class="@NavClass("Activities", "YearComparison")" asp-controller="Activities" asp-action="YearComparison">
                    <i class="bi bi-bar-chart-line"></i>Year vs Year
                </a>
                <a class="@NavClass("Activities", "ThisTimeLastYear")" asp-controller="Activities" asp-action="ThisTimeLastYear">
                    <i class="bi bi-clock-history"></i>This Time Last Year
                </a>
                <a class="@NavClass("Activities", "MonthComparison")" asp-controller="Activities" asp-action="MonthComparison">
                    <i class="bi bi-bar-chart"></i>Month vs Month
                </a>
                <a class="@NavClass("Activities", "Calendar")" asp-controller="Activities" asp-action="Calendar">
                    <i class="bi bi-calendar3"></i>Calendar
                </a>
                <a class="@NavClass("Activities", "DayInHistory")" asp-controller="Activities" asp-action="DayInHistory">
                    <i class="bi bi-calendar-event"></i>On This Day
                </a>
                <a class="@NavClass("Activities", "YearInReview")" asp-controller="Activities" asp-action="YearInReview">
                    <i class="bi bi-stars"></i>Year in Review
                </a>

                <div class="sidebar-section-label">Goals</div>
                <a class="@NavClass("Goals", null)" asp-controller="Goals" asp-action="Index">
                    <i class="bi bi-bullseye"></i>Goals &amp; Challenges
                </a>
                <a class="@NavClass("Activities", "Badges")" asp-controller="Activities" asp-action="Badges">
                    <i class="bi bi-award"></i>Badges
                </a>
                <a class="@NavClass("Activities", "Heatmap")" asp-controller="Activities" asp-action="Heatmap">
                    <i class="bi bi-map"></i>Heatmap
                </a>

            </nav>

            <!-- Footer utilities -->
            <div class="sidebar-footer">
                <button id="notif-btn" class="sidebar-util-btn" title="Enable activity reminders">
                    <i class="bi bi-bell"></i>
                </button>
                <button id="theme-toggle" class="sidebar-util-btn" title="Toggle light/dark theme">
                    <i class="bi bi-moon-stars" id="theme-icon"></i>
                </button>
                <form method="post" asp-controller="Strava" asp-action="ClearCache"
                      asp-route-returnUrl="@Context.Request.Path" class="d-inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="sidebar-util-btn" title="Clear cached Strava data and reload from API">
                        <i class="bi bi-arrow-clockwise"></i>
                    </button>
                </form>
                <span class="sidebar-cache-age" title="Data last fetched from Strava">@cacheAge</span>
                @if (string.IsNullOrEmpty(StravaOptions.Value.AccessToken))
                {
                    <a class="sidebar-link text-warning w-100 mt-1" asp-controller="Strava" asp-action="Authorize">
                        <i class="bi bi-link-45deg"></i>Connect Strava
                    </a>
                }
            </div>
        </div>
    </div>

    <!-- Main content -->
    <div class="app-content flex-grow-1">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
        <footer class="footer text-muted">
            &copy; 2026 - ActivitiesJournal - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </footer>
    </div>

</div>

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" crossorigin=""></script>
<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
